process {
  resourceLimits = [
      memory: 512.GB,
      cpus: 256,
      time: 7.d,
  ]

  cpus = { task.attempt }
  memory = { 16.GB * task.attempt }
  time = { 2.h * task.attempt }

  errorStrategy = { task.exitStatus in [140,137] ? 'retry' : 'finish' }
  maxRetries = 1
  maxErrors = '-1'
  
  cpus = 4
}
